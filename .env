# ════════════════════════════════════════════════════════
#  KuroHub — Environment Variables (Development)
# ════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000
WS_PORT=3001
FRONTEND_URL=http://localhost:5173
APP_NAME=KuroHub

JWT_ACCESS_SECRET=kurohub-dev-access-secret-min-32-char!!
JWT_REFRESH_SECRET=kurohub-dev-refresh-secret-juga-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kurohub
POSTGRES_USER=kurohub_user
POSTGRES_PASSWORD=kurohub_dev_pass_123

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=kurohub-dev-influx-token-min-32-chars-long
INFLUX_ORG=kurohub
INFLUX_BUCKET=telemetry
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=kurohub_influx_dev_pass

BCRYPT_ROUNDS=4
COOKIE_SECRET=kurohub-dev-cookie-secret

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

LOG_LEVEL=debug

PIN_MAX_NUMBER=255
DEVICE_OFFLINE_TIMEOUT_MS=60000
WS_TELEMETRY_RATE_LIMIT_MS=1000
